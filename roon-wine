#!/usr/bin/env bash
set -Eeuo pipefail

readonly APP_NAME=roon-wine
readonly DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/$APP_NAME"
readonly CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/$APP_NAME"
readonly CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}/$APP_NAME"
readonly PREFIX="$DATA_HOME/prefix"
readonly CONFIG_FILE="$CONFIG_HOME/config"
readonly INSTALLER_URL='https://download.roonlabs.com/builds/RoonInstaller64.exe'
readonly INSTALLER="$CACHE_HOME/RoonInstaller64.exe"
readonly PROTON_VERSION='GE-Proton11-1'
readonly PROTON_ARCHIVE="$CACHE_HOME/$PROTON_VERSION.tar.gz"
readonly PROTON_HOME="$DATA_HOME/runtimes"
readonly PROTON_PATH="$PROTON_HOME/$PROTON_VERSION"
readonly PROTON_URL="https://github.com/GloriousEggroll/proton-ge-custom/releases/download/$PROTON_VERSION/$PROTON_VERSION.tar.gz"
readonly PROTON_SHA512='d5792f4ac81d3832f5fe40467090c67d561b780c6a4236e76f8b59cb1d4ca25c82df91018e79d156bb267a67224a41f0d621a1e6cbbeec79040cc60275dc9e5a'

display=auto
audio=pipewire
scale=1.0
runner=proton

die() { printf 'roon-wine: %s\n' "$*" >&2; exit 1; }
note() { printf '==> %s\n' "$*"; }
have() { command -v "$1" >/dev/null 2>&1; }
valid_scale() {
  [[ $1 =~ ^[0-9]+([.][0-9]+)?$ ]] || return 1
  awk -v value="$1" 'BEGIN { exit !(value > 0) }'
}

usage() {
  cat <<'EOF'
Usage: roon-wine COMMAND [ARGUMENTS]

Commands:
  install                  Create/repair the prefix and install Roon
  run                      Launch Roon
  configure                Apply display and audio configuration
  winecfg                  Open Wine configuration for the managed prefix
  doctor                   Print compatibility diagnostics
  set display MODE         MODE: auto, wayland, xwayland
  set audio MODE           MODE: pipewire, pulse, alsa
  set scale FACTOR         Positive decimal UI scale
  set runner RUNNER        RUNNER: proton (default), wine
  runtime                  Install/verify the pinned Proton runtime
  kill                     Stop Wine processes in the managed prefix
  help                     Show this help
EOF
}

load_config() {
  [[ -f $CONFIG_FILE ]] || return 0
  while IFS='=' read -r key value; do
    case $key in
      display) [[ $value =~ ^(auto|wayland|xwayland)$ ]] && display=$value ;;
      audio) [[ $value =~ ^(pipewire|pulse|alsa)$ ]] && audio=$value ;;
      scale) valid_scale "$value" && scale=$value ;;
      runner) [[ $value =~ ^(proton|wine)$ ]] && runner=$value ;;
    esac
  done < "$CONFIG_FILE"
}

save_config() {
  mkdir -p "$CONFIG_HOME"
  umask 077
  printf 'display=%s\naudio=%s\nscale=%s\nrunner=%s\n' "$display" "$audio" "$scale" "$runner" > "$CONFIG_FILE"
}

wine_cmd() {
  local overrides='winemenubuilder.exe=d'
  [[ -n ${WINEDLLOVERRIDES:-} ]] && overrides="$WINEDLLOVERRIDES;$overrides"
  env WINEPREFIX="$PREFIX" WINEDLLOVERRIDES="$overrides" "$@"
}

install_runtime() {
  have umu-run || die 'umu-launcher is required for the Proton runner'
  have sha512sum || die 'sha512sum is required'
  [[ -x $PROTON_PATH/proton ]] && { note "using $PROTON_VERSION"; return; }
  mkdir -p "$CACHE_HOME" "$PROTON_HOME"
  note "downloading pinned runtime $PROTON_VERSION"
  curl --fail --location --retry 3 --continue-at - --output "$PROTON_ARCHIVE" "$PROTON_URL"
  printf '%s  %s\n' "$PROTON_SHA512" "$PROTON_ARCHIVE" | sha512sum --check --status \
    || die 'Proton runtime checksum verification failed'
  rm -rf "$PROTON_PATH"
  tar -xzf "$PROTON_ARCHIVE" -C "$PROTON_HOME"
  [[ -x $PROTON_PATH/proton ]] || die 'Proton runtime extraction failed'
}

proton_cmd() {
  install_runtime
  local wayland=0
  [[ $(selected_display) == wayland ]] && wayland=1
  env WINEPREFIX="$PREFIX" GAMEID=0 PROTONPATH="$PROTON_PATH" \
    PROTON_ENABLE_WAYLAND="$wayland" WINEDLLOVERRIDES="${WINEDLLOVERRIDES:-}" umu-run "$@"
}

runner_cmd() {
  if [[ $runner == proton ]]; then proton_cmd "$@"; else wine_cmd wine "$@"; fi
}

wine_major() {
  wine --version 2>/dev/null | sed -E 's/^[^0-9]*([0-9]+).*/\1/'
}

wayland_capable() {
  [[ ${XDG_SESSION_TYPE:-} == wayland && -n ${WAYLAND_DISPLAY:-} ]] || return 1
  [[ $runner == proton ]] && return 0
  [[ $(wine_major) =~ ^[0-9]+$ ]] && (( $(wine_major) >= 9 ))
}

selected_display() {
  if [[ $display == auto ]]; then
    if wayland_capable; then printf 'wayland\n'; else printf 'xwayland\n'; fi
  else
    printf '%s\n' "$display"
  fi
}

user_service_state() {
  local service state
  for service in "$@"; do
    state=$(systemctl --user is-active "$service" 2>/dev/null || true)
    [[ $state == active ]] && { printf 'active (%s)\n' "$service"; return 0; }
  done
  printf 'inactive or unavailable\n'
  return 1
}

configure_prefix() {
  [[ -d $PREFIX ]] || die "prefix does not exist; run 'roon-wine install' first"
  local selected
  selected=$(selected_display)
  if [[ $selected == wayland ]]; then
    wine_cmd wine reg add 'HKEY_CURRENT_USER\Software\Wine\Drivers' \
      /v Graphics /t REG_SZ /d wayland /f >/dev/null
  else
    wine_cmd wine reg delete 'HKEY_CURRENT_USER\Software\Wine\Drivers' \
      /v Graphics /f >/dev/null 2>&1 || true
  fi

  local wine_audio=pulse
  [[ $audio == alsa ]] && wine_audio=alsa
  wine_cmd wine reg add 'HKEY_CURRENT_USER\Software\Wine\Drivers' \
    /v Audio /t REG_SZ /d "$wine_audio" /f >/dev/null
  note "configured display=$selected audio=$audio"
}

open_winecfg() {
  [[ $runner == wine ]] || die "winecfg is only available with 'roon-wine set runner wine'"
  have winecfg || die 'winecfg is required'
  [[ -d $PREFIX ]] || die "prefix does not exist; run 'roon-wine install' first"
  local selected
  selected=$(selected_display)
  note "opening Wine configuration with display=$selected"
  if [[ $selected == wayland ]]; then
    env -u DISPLAY WINEPREFIX="$PREFIX" winecfg
  else
    wine_cmd winecfg
  fi
}

find_roon() {
  local candidate
  candidate=$(find "$PREFIX/drive_c/users" -type f \
    -path '*/AppData/Local/Roon/Application/Roon.exe' -print -quit 2>/dev/null || true)
  [[ -n $candidate ]] || return 1
  printf '%s\n' "$candidate"
}

install_roon() {
  have curl || die 'curl is required'
  mkdir -p "$DATA_HOME" "$CACHE_HOME"
  save_config

  if [[ $runner == wine && ! -d $PREFIX ]]; then
    note 'creating isolated 64-bit Wine prefix'
    env WINEARCH=win64 WINEPREFIX="$PREFIX" wineboot --init
  else
    note 'reusing existing prefix (no user data will be deleted)'
  fi

  if [[ $runner == proton ]]; then
    install_runtime
  else
    have wine || die 'wine is required for the Wine fallback'
    have winetricks || die 'winetricks is required for the Wine fallback'
    note 'installing required Windows runtime and prefix settings'
    env WINEPREFIX="$PREFIX" winetricks -q win10 dotnet7 nocrashdialog
    configure_prefix
  fi

  note 'downloading the current installer directly from Roon Labs'
  curl --fail --location --retry 3 --output "$INSTALLER.part" "$INSTALLER_URL"
  mv "$INSTALLER.part" "$INSTALLER"
  runner_cmd "$INSTALLER"
}

run_roon() {
  local exe selected
  exe=$(find_roon) || die "Roon is not installed; run 'roon-wine install'"
  selected=$(selected_display)
  [[ $runner == wine ]] && configure_prefix
  note "launching Roon with display=$selected audio=$audio scale=$scale"
  if [[ $selected == wayland ]]; then
    if [[ $runner == proton ]]; then
      (
        unset DISPLAY
        export WINEDEBUG=-all WINEDLLOVERRIDES='windows.media.mediacontrol='
        proton_cmd "$exe" "-scalefactor=$scale"
      )
    else
      env -u DISPLAY WINEPREFIX="$PREFIX" WINEDEBUG=-all \
        WINEDLLOVERRIDES='windows.media.mediacontrol=;winemenubuilder.exe=d' \
        wine "$exe" "-scalefactor=$scale"
    fi
  else
    if [[ $runner == proton ]]; then WINEDEBUG=-all proton_cmd "$exe" "-scalefactor=$scale"
    else wine_cmd env WINEDEBUG=-all wine "$exe" "-scalefactor=$scale"; fi
  fi
}

doctor() {
  load_config
  local failures=0 major='unknown'
  have wine && major=$(wine_major)
  printf '%-20s %s\n' 'session type' "${XDG_SESSION_TYPE:-unknown}"
  printf '%-20s %s\n' 'Wayland display' "${WAYLAND_DISPLAY:-not set}"
  printf '%-20s %s\n' 'X11 display' "${DISPLAY:-not set}"
  printf '%-20s %s\n' 'configured display' "$display -> $(selected_display 2>/dev/null || echo unavailable)"
  printf '%-20s %s\n' 'configured audio' "$audio"
  printf '%-20s %s\n' 'runner' "$runner"
  printf '%-20s %s\n' 'Proton runtime' "$([[ -x $PROTON_PATH/proton ]] && echo "$PROTON_VERSION present" || echo missing)"
  printf '%-20s %s\n' 'Wine' "$(wine --version 2>/dev/null || echo missing)"
  printf '%-20s %s\n' 'PipeWire' "$(user_service_state pipewire.service || true)"
  printf '%-20s %s\n' 'Pulse service' "$(user_service_state pipewire-pulse.service pulseaudio.service || true)"
  printf '%-20s %s\n' 'prefix' "$([[ -d $PREFIX ]] && echo present || echo missing)"
  printf '%-20s %s\n' 'Roon executable' "$(find_roon >/dev/null && echo present || echo missing)"

  if [[ $runner == proton ]]; then
    have umu-run || { printf 'WARN: umu-launcher is not installed\n' >&2; failures=1; }
  else
    have wine || { printf 'WARN: wine is not installed\n' >&2; failures=1; }
  fi
  if [[ $major == 11 ]]; then
    printf 'WARN: Wine 11 has a reported washed-out color regression with Roon\n' >&2
  fi
  if [[ $audio == pipewire ]] && ! systemctl --user is-active --quiet pipewire-pulse 2>/dev/null; then
    printf 'WARN: pipewire-pulse is not active; the local Roon output may be unavailable\n' >&2
    failures=1
  fi
  return "$failures"
}

set_value() {
  local key=${1:-} value=${2:-}
  case $key in
    display) [[ $value =~ ^(auto|wayland|xwayland)$ ]] || die 'display must be auto, wayland, or xwayland'; display=$value ;;
    audio) [[ $value =~ ^(pipewire|pulse|alsa)$ ]] || die 'audio must be pipewire, pulse, or alsa'; audio=$value ;;
    scale) valid_scale "$value" || die 'scale must be a positive decimal'; scale=$value ;;
    runner) [[ $value =~ ^(proton|wine)$ ]] || die 'runner must be proton or wine'; runner=$value ;;
    *) die 'setting must be display, audio, or scale' ;;
  esac
  save_config
  note "saved $key=$value"
}

main() {
  load_config
  case ${1:-help} in
    install) install_roon ;;
    run) run_roon ;;
    configure) configure_prefix ;;
    winecfg) open_winecfg ;;
    runtime) install_runtime ;;
    doctor) doctor ;;
    set) shift; set_value "${1:-}" "${2:-}" ;;
    kill)
      if [[ $runner == proton && -x $PROTON_PATH/files/bin/wineserver ]]; then
        WINEPREFIX="$PREFIX" "$PROTON_PATH/files/bin/wineserver" -k || true
      elif [[ -d $PREFIX ]]; then wine_cmd wineserver -k || true
      fi
      ;;
    help|-h|--help) usage ;;
    *) usage >&2; exit 2 ;;
  esac
}

main "$@"
